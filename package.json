{
  "name": "bilal-rms",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "backend"
  ],
  "optionalDependencies": {
    "lightningcss-linux-x64-gnu": "^1.30.2",
    "lightningcss-win32-x64-msvc": "^1.30.2"
  },
  "scripts": {
    "dev": "vite dev",
    "dev:server": "npm --workspace backend run dev",
    "dev:server:local": "npm run db:prepare && npm --workspace backend run dev",
    "dev:full": "npm run db:up && npm run env:local && concurrently -k -s first -n server,client \"npm:dev:server:local\" \"npm:dev\"",
    "build:client": "vite build",
    "build:server": "npm --workspace backend run build",
    "build": "npm run build:client && npm run build:server",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "start": "node scripts/start-production.mjs",
    "start:local": "node scripts/start-local-server.mjs",
    "postinstall": "npm --workspace backend run prisma:generate",
    "env:local": "node scripts/ensure-local-env.mjs",
    "db:up": "docker compose up -d mariadb",
    "db:down": "docker compose down --remove-orphans",
    "db:logs": "docker compose logs -f mariadb",
    "db:reset": "docker compose down --volumes --remove-orphans",
    "db:wait": "node scripts/wait-for-port.mjs 127.0.0.1 3307 180000 MariaDB bilal-rms-mariadb",
    "db:prepare": "npm run env:local && npm run db:wait && npm run db:deploy && npm run seed",
    "db:generate": "node scripts/run-backend-command.mjs npm --workspace backend run prisma:generate",
    "db:deploy": "node scripts/run-backend-command.mjs npm --workspace backend run prisma:deploy",
    "db:migrate": "node scripts/run-backend-command.mjs npm --workspace backend run prisma:migrate",
    "seed": "npm --workspace backend run seed",
    "seed:demo": "npm --workspace backend run seed:demo",
    "test:backend:services": "npm --workspace backend run test:services",
    "test:backend:integration": "npm --workspace backend run test:integration",
    "test:e2e": "npm run test:e2e:smoke && npm run test:e2e:regression",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:regression": "playwright test --project=regression",
    "test:e2e:live": "playwright test --config playwright.live.config.ts --project=live",
    "check:architecture": "node scripts/check-route-architecture.mjs",
    "check:deferred-routes": "node scripts/verify-deferred-admin-routes.mjs",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.25.5",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-start": "^1.167.14",
    "@tanstack/router-plugin": "^1.167.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lightningcss": "^1.30.2",
    "lucide-react": "^0.575.0",
    "nitro": "3.0.260603-beta",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.6.5",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "vaul": "^1.1.2",
    "vite-tsconfig-paths": "^6.0.2",
    "zod": "^3.24.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@eslint/js": "^9.32.0",
    "@lovable.dev/vite-tanstack-config": "2.7.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "prettier": "^3.7.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
